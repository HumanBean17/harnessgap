{
  "name": "harnessgap",
  "version": "0.1.0",
  "description": "Stateless detection-only CLI that finds harness gaps in Claude Code transcripts",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "harnessgap": "dist/cli.js"
  },
  "files": [
